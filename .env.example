# Team-shared environment template (do not commit real secrets)
# Copy to .env and fill values for your local machine.

OPENAI_API_KEY=

# Preferred single DB URL (works for backend and save_local_db)
# Example: mysql://root:password@13.209.64.184:3306/db
DATABASE_URL=

# Optional AWS MySQL parts (used when DATABASE_URL is empty)
AWS_MYSQL_HOST=
AWS_MYSQL_PORT=3306
AWS_MYSQL_USER=
AWS_MYSQL_PASSWORD=
AWS_MYSQL_DATABASE=
